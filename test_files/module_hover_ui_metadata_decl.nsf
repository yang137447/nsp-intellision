float u_b_distance_length
<
    string SasUiLabel = "Distance length";
    string SasUiControl = "FloatSlider";
    float SasUiMin = 0.0;
    float SasUiMax = 2000.0;
> = 800.0f;

float4 HoverUiEntry(float4 input) : SV_Target0
{
    half distance_to_camera = 10.0h;
    half distRatio = saturate(distance_to_camera / u_b_distance_length);
    return input * distRatio;
}
