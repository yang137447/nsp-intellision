#define USE_ACTIVE_BRANCH 0

#if USE_ACTIVE_BRANCH
// inactive branch doc
float4 SelectBranchColor(float2 uv)
{
    return float4(1.0, 0.0, 0.0, 1.0);
}
#else
// active branch doc
float4 SelectBranchColor(float2 uv)
{
    return float4(uv, 0.0, 1.0);
}
#endif

float4 PreprocDefinitionEntry(float2 uv : TEXCOORD0) : SV_Target0
{
    return SelectBranchColor(uv);
}
