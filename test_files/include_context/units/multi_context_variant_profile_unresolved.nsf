#include "../shared/multi_context_variant_profile_shared.hlsl"

float4 MultiContextVariantProfileUnresolvedEntry(float2 uv : TEXCOORD0) : SV_Target0
{
#if TARGET_VARIANT_PROFILE == 1
    VariantProfileResolvedType value = MakeVariantProfileValue();
#else
    VariantProfileFallbackType value = MakeVariantProfileValue();
#endif
    return float4(value.variant_value + uv.x, 0.0, 0.0, 1.0);
}
