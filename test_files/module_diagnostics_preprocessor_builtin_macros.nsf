float4 PreprocessorBuiltinMacroEval(float2 uv : TEXCOORD0) : SV_Target0
{
#if QUALITY_SUPPORT_MIDDLE && !PLAYERS_SELF
    return float4(uv, 0.0, 1.0);
#else
    float2 bad = float4(0.0, 0.0, 0.0, 0.0);
    return float4(uv, bad.x, 1.0);
#endif
}

float4 PreprocessorCompilerContextMacroEval(float2 uv : TEXCOORD0) : SV_Target0
{
#if API_MOBILE_HIGH_QUALITY || API_PC_HIGH_QUALITY || API_SUPPORT_SSBO || API_SUPPORT_SV_INSTANCE_ID || API_SUPPORT_TEXFETCH || API_SUPPORT_SV_VERTEX_ID || API_SUPPORT_FRAGCOORD || API_SUPPORT_TEXTURE_GATHER || SYSTEM_SUPPORT_DEPTH_BUFFER_AS_TEXTURE || GLES_USE_UBO || GL3_PROFILE || SYSTEM_SUPPORT_SRGB
    float2 bad = float4(0.0, 0.0, 0.0, 0.0);
    return float4(uv, bad.x, 1.0);
#else
    return float4(uv, 0.0, 1.0);
#endif
}

float4 PreprocessorStableSourceConstantEval(float2 uv : TEXCOORD0) : SV_Target0
{
#if EMISSIVE_COLOR == 1 && FOLIAGE_TREE_BRANCH == 1 && FOLIAGE_TREE_LEAF == 2 && FOLIAGE_GRASS_BRANCH == 3 && FOLIAGE_GRASS_LEAF == 4
    return float4(uv, 0.0, 1.0);
#else
    float2 bad = float4(0.0, 0.0, 0.0, 0.0);
    return float4(uv, bad.x, 1.0);
#endif
}

float4 PreprocessorLegacyUndefinedZeroEval(float2 uv : TEXCOORD0) : SV_Target0
{
#if COLOR_CHANGE_PICKER || COLOR_CHANGE_MULTIPLE || COLOR_CHANGE_GRADIENT || CHANNEL_COLOR_CHANGE || CHANNEL_COLOR_CHANGE_GRADIENT || CHANNEL_COLOR_CHANGE_ID || EMISSIVE_FLOW || EMISSIVE_FLOW_UV1 || EMISSIVE_PEARL || EMISSIVE_DISSOLVE_DISSORT || EMISSIVE_THIN_FILM || RENDER_VELOCITY || HAS_THIN_TRANSLUCENT || DYNAMIC_GI_TYPE || IS_MEADOW_LOD
    float2 bad = float4(0.0, 0.0, 0.0, 0.0);
    return float4(uv, bad.x, 1.0);
