struct PerfPayload {
  float4 color;
  float amount;
  float bias;
};

float4 BlendPerfColor(float4 baseColor, float amount, float bias) {
  return baseColor * amount + bias;
}

float4 BlendPerfAccum(PerfPayload payload, float2 uv) {
  float4 src = payload.color + float4(uv, 0.0, 1.0);
  float4 mixed = BlendPerfColor(src, payload.amount, payload.bias);
  return lerp(mixed, src, 0.25);
}

float4 PerfLargeMain(float2 uv : TEXCOORD0) : SV_Target {
