#define USE_LEGACY_STRUCT_MEMBERS 0

struct ConditionalMemberStruct
{
#if USE_LEGACY_STRUCT_MEMBERS
    float inactive_member;
#else
    float active_member;
    float active_gain;
#endif
};

float4 ConditionalMemberStructEntry(float2 uv : TEXCOORD0) : SV_Target0
{
    ConditionalMemberStruct instance;
    return instance.
}
