struct PixelMaterialParameters
{
    float3 world_position;
};

struct FGBufferData
{
    int ShadingModelID;
};

struct PixelData
{
    float4 color;
};

struct DeferredBasePassOutput
{
    float4 MRT0;
};

#define MAKE_MULTIPLIER(Type, Name, Value) Type Get##Name##Multiplier(PixelData p) { return Value; }
#define PREPARE_LOCAL_VALUES float localA = 1.0;\
    float localB = 2.0;

MAKE_MULTIPLIER(float3, SkyLightColor, p.color.xyz)

void ConvertToBasePassOutput(in PixelMaterialParameters materialParameters, in FGBufferData gbuffer, in PixelData p,
    inout DeferredBasePassOutput output)
{
    output.MRT0 = float4(materialParameters.world_position, p.color.x);
}

float3 BuildSplitReturn(float3 input)
{
    return float3(input.x
        , input.y
        , input.z);
}

float3 BuildSplitLerpReturn(float3 baseColor, float3 blendColor, float weight)
{
    return lerp(float3(baseColor.x, baseColor.y, baseColor.z),
        float3(blendColor.x, blendColor.y, blendColor.z),
        weight);
}

half3 BuildSplitHalfReturn(half3 normalBlur, half3 normalGreen, half3 normalBlue)
{
    return half3(normalBlur.x
        , normalGreen.y
        , normalBlue.z);
}

float
BuildReturnTypeSplitHeader(float value)
{
    return value;
}

float4 BuildNameSplitHeader
(
    float3 input
)
{
    return float4(input, 1.0);
}

float4 BuildSplitAssignment(float3 input)
{
    float4 accumulated = float4(input.x, input.y, input.z, 1.0)
        + float4(0.1, 0.2, 0.3, 0.0)
        + float4(input.z, input.y, input.x, 0.0);
    return accumulated;
}

void ComplexConditionBoundary(in FGBufferData gbuffer, inout PixelData p)
{
    if ((gbuffer.ShadingModelID == 1) ||
        (gbuffer.ShadingModelID == 2))
    {
        p.color.x = p.color.x + 1.0;
    }
}

float MacroStatementBoundary()
{
    PREPARE_LOCAL_VALUES
    return localA + localB;
}

float2 ArrayInitializerBoundary(int index)
{
    const float2 offsets[2] = {
        float2(0.0, 0.0),
        float2(1.0, 1.0)
    };
    return offsets[index];
}

technique InlinePassBoundary
{ pass p0
    {
        VertexShader = CompileShader(vs_3_0, ConvertToBasePassOutput());
    }
}
