{
  "id": "rw-ux-bumpoffset-warm-completion",
  "title": "Real workspace BumpOffsetUV warm completion capture",
  "workspaceHint": "shader-source",
  "targetDocument": {
    "workspaceFolderSuffix": "shader-source",
    "relativePath": "sfx/pbr_flow_water.nsf",
    "anchorText": "struct VS_INPUT",
    "occurrence": 1,
    "characterOffset": 0
  },
  "intent": "Capture completion after startup and quiescent warmup so reports separate cold-start pollution from steady-state interactive behavior.",
  "tags": ["interactive", "completion", "ux-capture", "real-workspace", "warm"],
  "steps": [
    {
      "kind": "openDocument",
      "label": "open unit document",
      "target": {
        "workspaceFolderSuffix": "shader-source",
        "relativePath": "sfx/pbr_flow_water.nsf",
        "anchorText": "struct VS_INPUT",
        "occurrence": 1,
        "characterOffset": 0
      },
      "afterActionPauseMs": 800
    },
    {
      "kind": "waitForInternalStatus",
      "label": "wait for internal status idle before warm completion capture",
      "payload": {
        "mode": "idle",
        "timeoutMs": 240000
      }
    },
    {
      "kind": "waitForInternalStatus",
      "label": "wait for internal status idle after initial warmup",
      "payload": {
        "mode": "idle",
        "timeoutMs": 240000
      }
    },
    {
      "kind": "captureWorkspaceSymbols",
      "label": "capture workspace symbols for BumpOffsetUV after warmup",
      "payload": {
        "query": "BumpOffsetUV",
        "expectedNames": ["BumpOffsetUV"],
        "maxNames": 50
      }
    },
    {
      "kind": "openDocument",
      "label": "open bumpoffset include document",
      "target": {
        "workspaceFolderSuffix": "shader-source",
        "relativePath": "sfx/nodes/pbr_flow_water_nodes.hlsl",
        "anchorText": "BumpOffsetUV(MaterialParameters, diffuse_sample_uv, u_maintex_height)",
        "occurrence": 1,
        "characterOffset": 0
      },
      "afterActionPauseMs": 200
    },
    {
      "kind": "selectRange",
      "label": "select function name",
      "target": {
        "workspaceFolderSuffix": "shader-source",
        "relativePath": "sfx/nodes/pbr_flow_water_nodes.hlsl",
        "anchorText": "BumpOffsetUV(MaterialParameters, diffuse_sample_uv, u_maintex_height)",
        "occurrence": 1,
        "characterOffset": 0
      },
      "payload": { "startOffset": 0, "endOffset": 12 }
    },
    {
      "kind": "typeText",
      "label": "type Bu",
      "payload": { "text": "Bu" }
    },
    {
      "kind": "captureCompletion",
      "label": "capture warm completion after Bu",
      "payload": { "expectedLabels": ["BumpOffsetUV"], "maxLabels": 80 },
      "samplingWindow": {
        "label": "ux-window",
        "delaysMs": [0, 30, 80, 160, 320, 640, 1200, 2400, 3600]
      }
    }
  ],
  "cleanup": { "restoreTouchedDocuments": true }
}
