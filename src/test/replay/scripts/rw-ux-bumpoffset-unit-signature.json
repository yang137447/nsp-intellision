{
  "id": "rw-ux-bumpoffset-unit-signature",
  "title": "Real workspace BumpOffsetUV signature help capture (with unit)",
  "workspaceHint": "shader-source",
  "targetDocument": {
    "workspaceFolderSuffix": "shader-source",
    "relativePath": "sfx/pbr_flow_water.nsf",
    "anchorText": "struct VS_INPUT",
    "occurrence": 1,
    "characterOffset": 0
  },
  "intent": "Capture signature help content and latency in pbr_flow_water_nodes.hlsl after opening a likely unit file to establish active-unit context.",
  "tags": ["interactive", "signature-help", "ux-capture", "real-workspace"],
  "steps": [
    {
      "kind": "openDocument",
      "label": "open unit document",
      "target": {
        "workspaceFolderSuffix": "shader-source",
        "relativePath": "sfx/pbr_flow_water.nsf",
        "anchorText": "struct VS_INPUT",
        "occurrence": 1,
        "characterOffset": 0
      },
      "afterActionPauseMs": 800
    },
    {
      "kind": "captureWorkspaceSymbols",
      "label": "capture workspace symbols for BumpOffsetUV",
      "payload": {
        "query": "BumpOffsetUV",
        "expectedNames": ["BumpOffsetUV"],
        "maxNames": 50
      }
    },
    {
      "kind": "waitForInternalStatus",
      "label": "wait for internal status idle before include signature capture",
      "payload": {
        "mode": "idle",
        "timeoutMs": 240000
      }
    },
    {
      "kind": "waitForInternalStatus",
      "label": "wait for client quiescent before include signature capture",
      "payload": {
        "mode": "quiescent",
        "timeoutMs": 240000
      }
    },
    {
      "kind": "openDocument",
      "label": "open bumpoffset include document",
      "target": {
        "workspaceFolderSuffix": "shader-source",
        "relativePath": "sfx/nodes/pbr_flow_water_nodes.hlsl",
    "relativePathAlternatives": ["shaderlib/surface_second_uv.hlsl"],
        "anchorText": "BumpOffsetUV(MaterialParameters, diffuse_sample_uv, u_maintex_height)",
    "anchorTextAlternatives": ["BumpOffsetUV(MaterialParameters, second_uv, height)", "BumpOffsetUV(MaterialParameters, second_uv , height)"],
        "occurrence": 1,
        "characterOffset": 0
      },
      "afterActionPauseMs": 200
    },
    {
      "kind": "selectRange",
      "label": "select function arguments",
      "target": {
        "workspaceFolderSuffix": "shader-source",
        "relativePath": "sfx/nodes/pbr_flow_water_nodes.hlsl",
    "relativePathAlternatives": ["shaderlib/surface_second_uv.hlsl"],
        "anchorText": "BumpOffsetUV(MaterialParameters, diffuse_sample_uv, u_maintex_height)",
    "anchorTextAlternatives": ["BumpOffsetUV(MaterialParameters, second_uv, height)", "BumpOffsetUV(MaterialParameters, second_uv , height)"],
        "occurrence": 1,
        "characterOffset": 0
      },
      "payload": { "startOffset": 12, "endOffset": 69 }
    },
    {
      "kind": "typeText",
      "label": "type open paren",
      "payload": { "text": "(" }
    },
    {
      "kind": "captureSignatureHelp",
      "label": "capture signature help after open paren",
      "payload": {
        "triggerCharacter": "(",
        "retrigger": false,
        "expectedSubstrings": ["BumpOffsetUV", "MaterialParameters", "coordinate_uv", "height"],
        "maxSignatures": 10
      },
      "samplingWindow": {
        "label": "ux-window",
        "delaysMs": [0, 30, 80, 160, 320, 640]
      }
    }
  ],
  "cleanup": { "restoreTouchedDocuments": true }
}

