    "workspaceFolderSuffix": "shader-source",
    "relativePath": "sfx/pbr_flow_water.nsf",
    "anchorText": "struct VS_INPUT",
    "occurrence": 1,
    "characterOffset": 0
  },
  "intent": "Replay a full pbr_flow_water include file input flow, sampling diagnostics, runtime state, completion, signature help, and metrics across the whole document.",
