{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2019",
    "lib": ["ES2019"],
    "outDir": "out",
    "rootDir": "src",
    "sourceMap": true,
    "moduleResolution": "node",
    "typeRoots": ["./node_modules/@types", "./client/node_modules/@types"],
    "types": ["node", "mocha", "vscode"]
  },
  "include": ["src"],
  "exclude": ["node_modules", ".vscode-test"],
  "references": [{ "path": "./client" }]
}
