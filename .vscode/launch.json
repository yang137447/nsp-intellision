{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "extensionHost",
      "request": "launch",
      "name": "Launch Client",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/client/out/**/*.js"
      ],
      "smartStep": true,
      "preLaunchTask": "npm: watch"
    },
    {
      "type": "extensionHost",
      "request": "launch",
      "name": "Launch Client (Open NSF Sample)",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions",
        "${workspaceFolder}",
        "${workspaceFolder}/test_files/main.nsf"
      ],
      "outFiles": [
        "${workspaceFolder}/client/out/**/*.js"
      ],
      "smartStep": true,
      "preLaunchTask": "npm: watch"
    }
  ]
}